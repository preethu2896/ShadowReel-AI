# ─────────────────────────────────────────────────────────────
#  ShadowReel AI  — Backend Service Environment Template
# ─────────────────────────────────────────────────────────────

# Core App Configurations
APP_NAME="ShadowReel AI Backend"
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=generate-a-secure-32-byte-hex-string-for-jwt-signing

# FastAPI Network Settings
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=["https://shadowreel.ai","https://www.shadowreel.ai","http://localhost:3000"]

# SQLite Local Override (set USE_SQLITE=false to run PostgreSQL)
USE_SQLITE=false
SQLITE_PATH=shadowreel.db
USE_FAKE_REDIS=false

# PostgreSQL Database (used if USE_SQLITE=false)
POSTGRES_USER=shadowreel_admin
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shadowreel_prod

# Redis Cache & Broker Settings (used if USE_FAKE_REDIS=false)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ComfyUI Connection (fastapi/celery workers need to contact the comfyui container or host node)
COMFYUI_HOST=comfyui_container
COMFYUI_PORT=8188

# Storage Options
OUTPUT_DIR=outputs/images
STATIC_URL_PREFIX=/static
MAX_FILE_SIZE_MB=100
CDN_BASE_URL=https://cdn.shadowreel.ai

# S3 Media Hosting (R2 / AWS S3)
S3_BUCKET=shadowreel-media
S3_ACCESS_KEY=your-aws-access-key-id
S3_SECRET_KEY=your-aws-secret-access-key
S3_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com

# Safety / Concurrency Limits
RATE_LIMIT_PER_MINUTE=20
MAX_CONCURRENT_JOBS=5

# Generation Defaults
DEFAULT_STEPS=20
DEFAULT_CFG=7.0
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
DEFAULT_SAMPLER=euler
DEFAULT_SCHEDULER=normal
