# ─────────────────────────────────────────────────────────────
#  ShadowReel AI  — Multi-Service Root Environment Template
# ─────────────────────────────────────────────────────────────

# App Settings
APP_NAME="ShadowReel AI"
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=generate-a-secure-32-byte-hex-string-for-jwt-signing

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=["https://shadowreel.ai","https://www.shadowreel.ai"]

# PostgreSQL Database
POSTGRES_USER=shadowreel_admin
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shadowreel_prod

# Redis Cache & Broker
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ComfyUI Cluster Endpoint
COMFYUI_HOST=comfyui-gpu-node
COMFYUI_PORT=8188

# Storage & CDN Settings
OUTPUT_DIR=outputs/images
STATIC_URL_PREFIX=/static
MAX_FILE_SIZE_MB=100
CDN_BASE_URL=https://cdn.shadowreel.ai

# S3 Compatible Media Storage
S3_BUCKET=shadowreel-media
S3_ACCESS_KEY=your-aws-access-key-id
S3_SECRET_KEY=your-aws-secret-access-key
S3_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com # Override for Cloudflare R2 / MinIO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20
MAX_CONCURRENT_JOBS=5

# Stripe Payments Placeholder
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
