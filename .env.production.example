# ─────────────────────────────────────────────────────────────
#  ShadowReel AI — Production Multi-Service Environment Template
# ─────────────────────────────────────────────────────────────
# Save this file as .env.production in the root directory
# to feed variables to the docker-compose.production.yml configuration.

# Core Application Settings
APP_NAME="ShadowReel AI"
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=generate-a-secure-32-byte-hex-string-for-jwt-signing

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=["https://shadowreel.ai","https://www.shadowreel.ai"]

# PostgreSQL Database (Container network name is 'postgres')
POSTGRES_USER=shadowreel_prod_admin
POSTGRES_PASSWORD=generate-a-secure-postgresql-password-here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shadowreel_prod

# Redis Cache & Message Broker (Container network name is 'redis')
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ComfyUI GPU Node Connection (Local container network, or external IP if separate host)
COMFYUI_HOST=comfyui-gpu-node
COMFYUI_PORT=8188

# Storage & CDN Settings
OUTPUT_DIR=outputs/images
STATIC_URL_PREFIX=/static
MAX_FILE_SIZE_MB=250
CDN_BASE_URL=https://cdn.shadowreel.ai

# S3 Compatible Media Storage (AWS S3, Cloudflare R2, MinIO)
S3_BUCKET=shadowreel-prod-media
S3_ACCESS_KEY=your-aws-access-key-id
S3_SECRET_KEY=your-aws-secret-access-key
S3_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com # Change if using Cloudflare R2 or MinIO

# Concurrency & Safety Rates
RATE_LIMIT_PER_MINUTE=20
MAX_CONCURRENT_JOBS=10

# Third-party Integrations
STRIPE_API_KEY=sk_live_replace_with_stripe_production_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_stripe_production_webhook_secret
CLOUDFLARE_API_TOKEN=cf_token_replace_with_cloudflare_production_token
CLOUDFLARE_ZONE_ID=cf_zone_replace_with_cloudflare_zone_id
